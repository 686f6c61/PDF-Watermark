---
import BaseLayout from "../layouts/BaseLayout.astro";
import PrivacyContent from "../components/PrivacyContent.svelte";
import { t } from "../i18n/t";

const lang = "es" as const;
---

<BaseLayout
  lang={lang}
  title={t("meta.privacyTitle", lang)}
  description={t("meta.privacyDescription", lang)}
  canonicalPath="/privacidad/"
  alternatePaths={{ es: "/privacidad/", en: "/en/privacy/" }}
  ogType="article"
  ogTitle={t("meta.privacyOgTitle", lang)}
  ogDescription={t("meta.privacyOgDescription", lang)}
>
  <PrivacyContent {lang} />
</BaseLayout>
