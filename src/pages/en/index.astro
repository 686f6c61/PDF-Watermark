---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Editor from "../../components/Editor.svelte";
import { t } from "../../i18n/t";

const lang = "en" as const;

// Structured data (Schema.org): WebApplication
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "PDF Watermark",
  "url": "https://pdf-watermark.686f6c61.dev/en/",
  "description": t("meta.indexDescription", "en"),
  "applicationCategory": "UtilityApplication",
  "operatingSystem": "Web",
  "browserRequirements": "Requires JavaScript",
  "inLanguage": "en",
  "isAccessibleForFree": true,
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "EUR"
  },
  "featureList": [
    "100% local browser processing",
    "Watermarks for PDF",
    "Watermarks for images (PNG, JPG, WebP)",
    "Four patterns: diagonal, single centered, corner, spiral",
    "Batch processing with ZIP download",
    "Page selection in multi-page PDFs",
    "Draggable before/after preview",
    "No telemetry by default, GDPR compliant"
  ],
  "screenshot": "https://pdf-watermark.686f6c61.dev/og-image-en.png"
};
---

<BaseLayout
  lang={lang}
  title={t("meta.indexTitle", lang)}
  description={t("meta.indexDescription", lang)}
  canonicalPath="/en/"
  alternatePaths={{ es: "/", en: "/en/" }}
  keywords={t("meta.indexKeywords", lang)}
  ogTitle={t("meta.ogTitle", lang)}
  ogDescription={t("meta.ogDescription", lang)}
  twitterDescription={t("meta.twitterDescription", lang)}
  ogImageAlt={t("meta.ogImageAlt", lang)}
  withAuthor
  withSitemapLink
  withSiteVerification
  withPrivacyBadge
  withServiceWorker
  jsonLd={jsonLd}
>
  <main>
    <Editor client:load {lang} />
  </main>
</BaseLayout>
