---
import BaseLayout from "../layouts/BaseLayout.astro";
import Editor from "../components/Editor.svelte";
import { t } from "../i18n/t";

const lang = "es" as const;

// Datos estructurados Schema.org: WebApplication
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "PDF Watermark",
  "url": "https://pdf-watermark.686f6c61.dev/",
  "description": t("meta.indexDescription", "es"),
  "applicationCategory": "UtilityApplication",
  "operatingSystem": "Web",
  "browserRequirements": "Requires JavaScript",
  "inLanguage": "es-ES",
  "isAccessibleForFree": true,
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "EUR"
  },
  "featureList": [
    "Procesamiento 100% local en navegador",
    "Marcas de agua para PDF",
    "Marcas de agua para imágenes (PNG, JPG, WebP)",
    "Cuatro patrones: diagonal, único centrado, esquina, espiral",
    "Procesamiento por lotes con descarga en ZIP",
    "Selección de páginas en PDFs multipágina",
    "Vista previa antes y después arrastrable",
    "Sin telemetría por defecto, RGPD compliant"
  ],
  "screenshot": "https://pdf-watermark.686f6c61.dev/og-image.png"
};
---

<BaseLayout
  lang={lang}
  title={t("meta.indexTitle", lang)}
  description={t("meta.indexDescription", lang)}
  canonicalPath="/"
  alternatePaths={{ es: "/", en: "/en/" }}
  keywords={t("meta.indexKeywords", lang)}
  ogTitle={t("meta.ogTitle", lang)}
  ogDescription={t("meta.ogDescription", lang)}
  twitterDescription={t("meta.twitterDescription", lang)}
  ogImageAlt={t("meta.ogImageAlt", lang)}
  withAuthor
  withSitemapLink
  withSiteVerification
  withPrivacyBadge
  withLangRedirect
  withServiceWorker
  jsonLd={jsonLd}
>
  <main>
    <Editor client:load {lang} />
  </main>
</BaseLayout>
