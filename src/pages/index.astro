---
import Editor from "../components/Editor.svelte";
import PrivacyBadge from "../components/PrivacyBadge.svelte";
import CookieBanner from "../components/CookieBanner.svelte";
import LanguageSwitcher from "../components/LanguageSwitcher.svelte";
import { t } from "../i18n/t";
import "../styles/global.css";

const lang = "es" as const;
---

<!doctype html>
<html lang={t("meta.htmlLang", lang)}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light" />
    <meta name="theme-color" content="#FFF8E7" />

    <title>{t("meta.indexTitle", lang)}</title>
    <meta name="description" content={t("meta.indexDescription", lang)} />
    <meta name="keywords" content={t("meta.indexKeywords", lang)} />
    <meta name="author" content="PDF Watermark" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://pdf-watermark.686f6c61.dev/" />

    <!-- Alternates hreflang para SEO multilingüe -->
    <link rel="alternate" hreflang="es" href="https://pdf-watermark.686f6c61.dev/" />
    <link rel="alternate" hreflang="en" href="https://pdf-watermark.686f6c61.dev/en/" />
    <link rel="alternate" hreflang="x-default" href="https://pdf-watermark.686f6c61.dev/" />

    <!-- Favicon e iconos -->
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <!-- PWA: manifiesto e instalacion en escritorio/movil -->
    <link rel="manifest" href="/manifest.webmanifest" />

    <!-- Open Graph / Facebook / WhatsApp / LinkedIn -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="PDF Watermark" />
    <meta property="og:locale" content={t("meta.ogLocale", lang)} />
    <meta property="og:locale:alternate" content="en_US" />
    <meta property="og:url" content="https://pdf-watermark.686f6c61.dev/" />
    <meta property="og:title" content={t("meta.ogTitle", lang)} />
    <meta property="og:description" content={t("meta.ogDescription", lang)} />
    <meta property="og:image" content="https://pdf-watermark.686f6c61.dev/og-image.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:alt" content={t("meta.ogImageAlt", lang)} />

    <!-- Twitter / X Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={t("meta.ogTitle", lang)} />
    <meta name="twitter:description" content={t("meta.twitterDescription", lang)} />
    <meta name="twitter:image" content="https://pdf-watermark.686f6c61.dev/og-image.png" />
    <meta name="twitter:image:alt" content={t("meta.ogImageAlt", lang)} />

    <!-- Sitemap -->
    <link rel="sitemap" type="application/xml" href="/sitemap.xml" />

    <!-- Verificacion de propiedad para Google Search Console -->
    <meta name="google-site-verification" content="SmBuD0MsgAZgjuPh-qcRw2hWjLmOTF1oceXqWKIqohA" />

    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-2G7BTJZ72T" is:inline></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'G-2G7BTJZ72T');
    </script>

    <!-- Datos estructurados Schema.org: WebApplication -->
    <script type="application/ld+json" is:inline set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "PDF Watermark",
      "url": "https://pdf-watermark.686f6c61.dev/",
      "description": t("meta.indexDescription", "es"),
      "applicationCategory": "UtilityApplication",
      "operatingSystem": "Web",
      "browserRequirements": "Requires JavaScript",
      "inLanguage": "es-ES",
      "isAccessibleForFree": true,
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "EUR"
      },
      "featureList": [
        "Procesamiento 100% local en navegador",
        "Marcas de agua para PDF",
        "Marcas de agua para imágenes (PNG, JPG, WebP)",
        "Cuatro patrones: diagonal, único centrado, esquina, espiral",
        "Procesamiento por lotes con descarga en ZIP",
        "Selección de páginas en PDFs multipágina",
        "Vista previa antes y después arrastrable",
        "Sin telemetría por defecto, RGPD compliant"
      ],
      "screenshot": "https://pdf-watermark.686f6c61.dev/og-image.png"
    })} />

    <!-- Redireccion automatica a /en/ en primera visita si el navegador es ingles -->
    <script is:inline>
      (function () {
        try {
          var STORAGE_KEY = "pdf-watermark-lang-pref";
          var pref = localStorage.getItem(STORAGE_KEY);
          if (pref) return; // El usuario ya eligio: respetamos su decision.
          var primary = (navigator.language || "").toLowerCase().split("-")[0];
          if (primary === "en") {
            localStorage.setItem(STORAGE_KEY, "auto-en");
            window.location.replace("/en/");
          }
        } catch (err) {
          // localStorage o navigator.language inaccesibles: no hacemos nada.
        }
      })();
    </script>
  </head>
  <body>
    <header class="page-header">
      <a class="brand" href="/">{t("header.brand", lang)}</a>
      <div class="header-right">
        <PrivacyBadge {lang} />
        <LanguageSwitcher {lang} />
      </div>
    </header>

    <main>
      <Editor client:load {lang} />
    </main>

    <footer class="page-footer">
      <p>{t("footer.tagline", lang)}</p>
      <nav class="footer-links" aria-label={t("footer.linksAria", lang)}>
        <a href="/privacidad/">{t("footer.privacy", lang)}</a>
        <button type="button" class="footer-button" data-cookie-settings>
          {t("cookies.configureFooter", lang)}
        </button>
        <a
          href="https://github.com/686f6c61/PDF-Watermark"
          rel="noopener noreferrer"
          target="_blank"
          class="github-link"
          aria-label={t("footer.githubAria", lang)}
        >
          <svg
            aria-hidden="true"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="currentColor"
          >
            <path d="M12 0.5C5.65 0.5 0.5 5.65 0.5 12c0 5.08 3.29 9.39 7.86 10.91.58.1.79-.25.79-.56v-2.05c-3.2.7-3.87-1.37-3.87-1.37-.52-1.33-1.27-1.69-1.27-1.69-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.02 1.75 2.68 1.24 3.34.95.1-.74.4-1.24.73-1.53-2.55-.29-5.24-1.28-5.24-5.69 0-1.26.45-2.29 1.18-3.1-.12-.29-.51-1.46.11-3.04 0 0 .96-.31 3.15 1.18a10.96 10.96 0 0 1 5.74 0c2.18-1.49 3.14-1.18 3.14-1.18.63 1.58.23 2.75.12 3.04.74.81 1.18 1.84 1.18 3.1 0 4.42-2.69 5.4-5.26 5.69.41.36.78 1.06.78 2.13v3.16c0 .31.21.67.8.56C20.22 21.39 23.5 17.08 23.5 12 23.5 5.65 18.35 0.5 12 0.5z" />
          </svg>
          <span>{t("footer.github", lang)}</span>
        </a>
        <a
          href="https://x.com/686f6c61"
          rel="noopener noreferrer"
          target="_blank"
          class="github-link"
          aria-label="@686f6c61 en X"
        >
          <svg
            aria-hidden="true"
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="currentColor"
          >
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
          </svg>
          <span>X</span>
        </a>
      </nav>
    </footer>

    <CookieBanner client:load {lang} />

    <script>
      import { initAnalytics } from "../lib/analytics";
      import { reopenBanner } from "../components/CookieBanner.svelte";

      initAnalytics();

      // Conecta el boton "Configurar cookies" del footer con el banner.
      document.querySelectorAll<HTMLButtonElement>("[data-cookie-settings]").forEach((btn) => {
        btn.addEventListener("click", () => reopenBanner());
      });

      // Marcar la preferencia de idioma cuando el usuario navega a las rutas /en/.
      // Lo hacemos en /en/ y /privacidad/ por igual; aqui en /, recordamos `es`.
      try {
        localStorage.setItem("pdf-watermark-lang-pref", "es");
      } catch {
        // no-op
      }

      // Registro del Service Worker (PWA: instalable + offline).
      if ("serviceWorker" in navigator && location.protocol === "https:") {
        window.addEventListener("load", () => {
          navigator.serviceWorker.register("/sw.js", { scope: "/" }).catch((err) => {
            console.warn("Service Worker no registrado:", err);
          });
        });
      }
    </script>

    <style is:global>
      .page-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: var(--space-4) var(--space-5);
        border-bottom: var(--border-thick);
        background: var(--bg);
        position: sticky;
        top: 0;
        z-index: 20;
      }
      .header-right {
        display: inline-flex;
        align-items: center;
        gap: var(--space-3);
        flex-wrap: wrap;
      }
      .brand {
        font-family: var(--font-display);
        font-weight: 800;
        font-size: var(--text-h2);
        color: var(--ink);
        text-decoration: none;
        text-transform: uppercase;
        letter-spacing: 0.04em;
      }
      main {
        min-height: calc(100vh - 200px);
      }
      .page-footer {
        padding: var(--space-5);
        text-align: center;
        border-top: var(--border-thin);
        color: var(--ink-muted);
        font-size: var(--text-small);
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: var(--space-3);
      }
      .footer-links {
        display: inline-flex;
        align-items: center;
        gap: var(--space-3);
      }
      .footer-links a {
        color: inherit;
        text-decoration: none;
        font-weight: 600;
        border-bottom: 2px solid transparent;
      }
      .footer-links a:hover {
        border-bottom-color: var(--ink);
      }
      .footer-button {
        background: transparent;
        border: none;
        color: inherit;
        font-weight: 600;
        font-size: inherit;
        font-family: inherit;
        padding: 0;
        text-decoration: underline;
        text-underline-offset: 3px;
      }
      .footer-button:hover {
        color: var(--ink);
      }
      .github-link {
        display: inline-flex;
        align-items: center;
        gap: var(--space-1);
        background: var(--surface);
        border: var(--border-thin);
        box-shadow: var(--shadow-default);
        padding: var(--space-1) var(--space-3);
        border-radius: var(--radius-sm);
        color: var(--ink);
        transition: transform var(--motion-hover), box-shadow var(--motion-hover);
      }
      .github-link:hover {
        transform: translate(2px, 2px);
        box-shadow: var(--shadow-hover);
        border-bottom-color: transparent;
      }
    </style>
  </body>
</html>
