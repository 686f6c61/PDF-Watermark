---
import { t, type Lang } from "../i18n/t";
import pkg from "../../package.json";
import { Content as ChangelogContent } from "../../CHANGELOG.md";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const privacyHref = lang === "es" ? "/privacidad/" : "/en/privacy/";
---

<footer class="page-footer">
  <p>{t("footer.tagline", lang)}</p>
  <nav class="footer-links" aria-label={t("footer.linksAria", lang)}>
    <button
      type="button"
      class="footer-button"
      data-changelog-open
      aria-haspopup="dialog"
    >
      v{pkg.version} · {t("footer.changelog", lang)}
    </button>
    <a href={privacyHref}>{t("footer.privacy", lang)}</a>
    <button type="button" class="footer-button" data-cookie-settings>
      {t("cookies.configureFooter", lang)}
    </button>
    <a
      href="https://github.com/686f6c61/PDF-Watermark"
      rel="noopener noreferrer"
      target="_blank"
      class="github-link"
      aria-label={t("footer.githubAria", lang)}
    >
      <svg
        aria-hidden="true"
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="currentColor"
      >
        <path d="M12 0.5C5.65 0.5 0.5 5.65 0.5 12c0 5.08 3.29 9.39 7.86 10.91.58.1.79-.25.79-.56v-2.05c-3.2.7-3.87-1.37-3.87-1.37-.52-1.33-1.27-1.69-1.27-1.69-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.02 1.75 2.68 1.24 3.34.95.1-.74.4-1.24.73-1.53-2.55-.29-5.24-1.28-5.24-5.69 0-1.26.45-2.29 1.18-3.1-.12-.29-.51-1.46.11-3.04 0 0 .96-.31 3.15 1.18a10.96 10.96 0 0 1 5.74 0c2.18-1.49 3.14-1.18 3.14-1.18.63 1.58.23 2.75.12 3.04.74.81 1.18 1.84 1.18 3.1 0 4.42-2.69 5.4-5.26 5.69.41.36.78 1.06.78 2.13v3.16c0 .31.21.67.8.56C20.22 21.39 23.5 17.08 23.5 12 23.5 5.65 18.35 0.5 12 0.5z" />
      </svg>
      <span>{t("footer.github", lang)}</span>
    </a>
    <a
      href="https://x.com/686f6c61"
      rel="noopener noreferrer"
      target="_blank"
      class="github-link"
      aria-label="X (@686f6c61)"
    >
      <svg
        aria-hidden="true"
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="currentColor"
      >
        <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
      </svg>
    </a>
  </nav>
</footer>

<!-- Popup de novedades: dialog nativo (Esc cierra, foco atrapado, top layer).
     El contenido es el CHANGELOG.md compilado en build, asi que nunca se
     desincroniza de la version real del paquete. -->
<dialog class="changelog-modal" data-changelog-dialog aria-label={t("footer.changelog", lang)}>
  <div class="modal-head">
    <h2>{t("footer.changelogTitle", lang)} <span class="modal-version">v{pkg.version}</span></h2>
    <button type="button" class="modal-close" data-changelog-close>
      {t("footer.changelogClose", lang)}
    </button>
  </div>
  <div class="modal-body">
    <ChangelogContent />
  </div>
</dialog>

<script>
  const changelogDialog =
    document.querySelector<HTMLDialogElement>("[data-changelog-dialog]");
  const changelogOpen = document.querySelector("[data-changelog-open]");
  changelogOpen?.addEventListener("click", () => changelogDialog?.showModal());
  changelogDialog
    ?.querySelector("[data-changelog-close]")
    ?.addEventListener("click", () => changelogDialog.close());
  // Cierra al hacer clic fuera de la caja (backdrop). El backdrop no es un
  // elemento real, asi que se detecta por coordenadas a nivel document. El
  // clic del boton de apertura se excluye: abriria y cerraria a la vez.
  document.addEventListener("click", (event) => {
    if (!changelogDialog?.open) return;
    if (changelogOpen && event.composedPath().includes(changelogOpen)) return;
    const rect = changelogDialog.getBoundingClientRect();
    const inside =
      event.clientX >= rect.left &&
      event.clientX <= rect.right &&
      event.clientY >= rect.top &&
      event.clientY <= rect.bottom;
    if (!inside) changelogDialog.close();
  });
</script>

<style>
  .changelog-modal {
    /* Centrado explicito: sin position:fixed + inset:0 el UA lo coloca en la
       esquina superior izquierda (position:absolute con margin:auto solo
       centra si left/right son 0), y el backdrop-click por coordenadas dejaba
       de tener sentido. */
    position: fixed;
    inset: 0;
    margin: auto;
    border: var(--border-thick);
    box-shadow: var(--shadow-hover);
    border-radius: var(--radius-lg);
    background: var(--surface);
    color: var(--ink);
    padding: 0;
    width: min(640px, 92vw);
    height: fit-content;
    max-height: 82vh;
    /* display solo cuando esta abierto: un display fijo anularia el
       display:none del UA para dialogs cerrados y se veria siempre. */
  }
  .changelog-modal[open] {
    display: flex;
    flex-direction: column;
  }
  .changelog-modal::backdrop {
    background: rgba(26, 26, 26, 0.45);
  }
  .modal-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    padding: var(--space-4) var(--space-5);
    border-bottom: var(--border-thin);
  }
  .modal-head h2 {
    margin: 0;
    font-size: var(--text-h2);
  }
  .modal-version {
    color: var(--ink-muted);
    font-weight: 600;
  }
  .modal-close {
    background: var(--surface);
    border: var(--border-thin);
    box-shadow: var(--shadow-default);
    border-radius: var(--radius-sm);
    padding: var(--space-1) var(--space-3);
    font-family: inherit;
    font-size: var(--text-small);
    font-weight: 700;
    cursor: pointer;
    transition:
      transform var(--motion-hover),
      box-shadow var(--motion-hover);
  }
  .modal-close:hover {
    transform: translate(2px, 2px);
    box-shadow: var(--shadow-hover);
  }
  .modal-body {
    padding: var(--space-4) var(--space-5);
    overflow-y: auto;
    text-align: left;
  }
  /* El CHANGELOG.md lleva su propio H1 "Changelog": el modal ya muestra el
     titulo en la cabecera, asi que se oculta para no duplicarlo. */
  .modal-body :global(h1) {
    display: none;
  }
  .modal-body :global(h2) {
    font-size: 1.15rem;
    margin: var(--space-4) 0 var(--space-2);
  }
  .modal-body :global(h3) {
    font-size: 0.95rem;
    margin: var(--space-3) 0 var(--space-1);
  }
  .modal-body :global(p),
  .modal-body :global(li) {
    font-size: var(--text-small);
    line-height: 1.5;
  }
  .modal-body :global(ul) {
    padding-left: 1.2em;
  }
  .modal-body :global(li) {
    margin-bottom: 0.35em;
  }
  .modal-body :global(hr) {
    border: none;
    border-top: var(--border-thin);
    margin: var(--space-4) 0;
  }
</style>
